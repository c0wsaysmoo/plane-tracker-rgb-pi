# Plane Tracker Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For systemd deployment, install-service.sh copies .env to /etc/plane-tracker.env

# === API Keys (SECRETS — replace with your own) ===
FR24_API_KEY=your_subscription_key|your_token
TOMORROW_API_KEY=your_tomorrow_api_key

# === Bounding Box (overhead detection zone) ===
# Use https://www.latlong.net/ or Google Maps to find corners of your area
ZONE_TL_LAT=51.595
ZONE_TL_LON=-0.314
ZONE_BR_LAT=51.47
ZONE_BR_LON=-0.111

# === Home location (for distance calculations) ===
HOME_LAT=51.55864
HOME_LON=-0.177332

# === Weather ===
TEMPERATURE_LOCATION=51.55864,-0.177332
TEMPERATURE_UNITS=metric
FORECAST_DAYS=3

# === Display & units ===
# DISTANCE_UNITS: "metric" or "imperial"
DISTANCE_UNITS=imperial
# CLOCK_FORMAT: "12hr" or "24hr"
CLOCK_FORMAT=12hr
BRIGHTNESS=100
BRIGHTNESS_NIGHT=50
# NIGHT_BRIGHTNESS: True to enable dimming between NIGHT_START and NIGHT_END
NIGHT_BRIGHTNESS=True
NIGHT_START=20:00
NIGHT_END=06:00
# GPIO_SLOWDOWN: 2 for Pi 3, 1 for Pi Zero
GPIO_SLOWDOWN=2
HAT_PWM_ENABLED=True

# === Flight filtering ===
# MIN_ALTITUDE: feet above sea level (filters out low GA traffic)
MIN_ALTITUDE=1000
# JOURNEY_CODE_SELECTED: your home airport IATA code (e.g. LHR, ORD, JFK)
JOURNEY_CODE_SELECTED=LHR
JOURNEY_BLANK_FILLER= ?
# SPEED_UNITS: "imperial" (mph), "metric" (km/h), or "knots"
SPEED_UNITS=imperial
# SEARCH_RADIUS_NM: nautical miles from home to search for aircraft
# If not set, computed from bounding box (minimum 10nm)
#SEARCH_RADIUS_NM=10

# === Logging & notifications ===
# EMAIL: leave empty for no email alerts, or set to your address
EMAIL=
MAX_FARTHEST=3
MAX_CLOSEST=3

# === Route Fallback Chain (optional) ===
# Sources tried in order when adsbdb fails. Comma-separated.
# Available: "fr24", "airlabs", "flightaware"
# Without any keys, system works on adsb.lol + adsbdb alone (~70% route coverage).
#ROUTE_FALLBACK_CHAIN=airlabs,flightaware
# AirLabs: free, 1000 calls/month per key (https://airlabs.co/)
#AIRLABS_API_KEY=your_airlabs_key
# FlightAware AeroAPI: $5/month free credit (~830 calls at $0.006/call)
#FLIGHTAWARE_API_KEY=your_flightaware_key
#FLIGHTAWARE_MONTHLY_LIMIT=4.50
# FR24 Official REST API: $9/month Explorer plan (https://fr24api.flightradar24.com/)
#FLIGHTRADAR24_KEY=your_fr24_bearer_token
