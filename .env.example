# FlightRadar24 Official API credentials
# Format: "subscription_key|token"
# Get these from your FR24 account at https://www.flightradar24.com
FR24_API_KEY=your_subscription_key|your_token

# Tomorrow.io weather API key
# Get one at https://www.tomorrow.io (free tier: 25 requests/hour)
TOMORROW_API_KEY=your_tomorrow_api_key_here
