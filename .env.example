# ═══════════════════════════════════════════════════════════════════════════════
# Plane Tracker — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# ALL configuration lives here — config.py reads exclusively from env vars.
# No defaults are hardcoded in source code for user-specific values.
#
# Setup:
#   cp .env.example .env
#   nano .env           # Fill in your values
#
# For systemd deployment, install-service.sh copies .env to /etc/plane-tracker.env
# ═══════════════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ API Keys (REQUIRED — replace with your own)                                 │
# └─────────────────────────────────────────────────────────────────────────────┘

# FlightRadar24 subscription key and token (format: "subscription_key|token")
FR24_API_KEY=

# Tomorrow.io weather API key (https://www.tomorrow.io/weather-api/)
TOMORROW_API_KEY=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Location — Bounding Box (REQUIRED for overhead detection)                   │
# └─────────────────────────────────────────────────────────────────────────────┘
# Use https://www.latlong.net/ or Google Maps to find corners of your area.
# Top-left = north-west corner, Bottom-right = south-east corner.

ZONE_TL_LAT=
ZONE_TL_LON=
ZONE_BR_LAT=
ZONE_BR_LON=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Home Location (REQUIRED — for distance calculations)                        │
# └─────────────────────────────────────────────────────────────────────────────┘

HOME_LAT=
HOME_LON=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Weather                                                                     │
# └─────────────────────────────────────────────────────────────────────────────┘

# Comma-separated lat,lon for weather lookups (usually same as HOME_LAT,HOME_LON)
TEMPERATURE_LOCATION=

# Units: "metric" (°C) or "imperial" (°F)
TEMPERATURE_UNITS=metric

# Number of forecast days to display (1-5)
FORECAST_DAYS=3

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Display & Units                                                             │
# └─────────────────────────────────────────────────────────────────────────────┘

# Distance: "metric" (km) or "imperial" (miles)
DISTANCE_UNITS=metric

# Clock: "12hr" or "24hr"
CLOCK_FORMAT=24hr

# LED brightness (0-100)
BRIGHTNESS=100

# Night-mode brightness (0-100, used when NIGHT_BRIGHTNESS=True)
BRIGHTNESS_NIGHT=50

# Enable night dimming? (True/False)
NIGHT_BRIGHTNESS=False

# Night mode time window (HH:MM format)
NIGHT_START=22:00
NIGHT_END=06:00

# GPIO slowdown: 2 for Pi 3/4, 1 for Pi Zero
GPIO_SLOWDOWN=2

# PWM on the RGB HAT (True/False)
HAT_PWM_ENABLED=True

# Bonnet type: "single" (Adafruit RGB Matrix Bonnet) or "triple" (Adafruit Triple Bonnet)
BONNET_TYPE=single

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Flight Filtering                                                            │
# └─────────────────────────────────────────────────────────────────────────────┘

# Minimum altitude in feet (filters low GA traffic; 0 = no filter)
MIN_ALTITUDE=0

# Your home airport IATA code (e.g. LHR, ORD, JFK, SFO)
JOURNEY_CODE_SELECTED=

# Filler text shown when journey info is unknown
JOURNEY_BLANK_FILLER= ?

# Speed: "imperial" (mph), "metric" (km/h), or "knots"
SPEED_UNITS=metric

# Search radius in nautical miles from home for aircraft detection.
# If not set, computed from the bounding box (minimum 10nm).
#SEARCH_RADIUS_NM=10

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Logging & Notifications                                                     │
# └─────────────────────────────────────────────────────────────────────────────┘

# Email address for alerts (leave empty to disable)
EMAIL=

# Number of farthest/closest flights to track
MAX_FARTHEST=3
MAX_CLOSEST=3

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Route Fallback Chain (optional — improves route coverage)                   │
# └─────────────────────────────────────────────────────────────────────────────┘
# Sources tried in order when adsbdb fails. Comma-separated.
# Available: "fr24", "airlabs", "flightaware"
# Without any keys, system works on adsb.lol + adsbdb alone (~70% route coverage).
#ROUTE_FALLBACK_CHAIN=airlabs,flightaware

# AirLabs: free, 1000 calls/month per key (https://airlabs.co/)
#AIRLABS_API_KEY=

# FlightAware AeroAPI: $5/month free credit (~830 calls at $0.006/call)
#FLIGHTAWARE_API_KEY=
#FLIGHTAWARE_MONTHLY_LIMIT=4.50

# FR24 Official REST API: $9/month Explorer plan (https://fr24api.flightradar24.com/)
#FLIGHTRADAR24_KEY=
