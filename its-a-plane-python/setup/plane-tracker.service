[Unit]
Description=Plane Tracker RGB LED Matrix Display
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Secrets and config loaded from environment file
EnvironmentFile=/etc/plane-tracker.env
WorkingDirectory=__REPO_DIR__/its-a-plane-python

# Fix permissions on writable data files/dirs before starting
ExecStartPre=/bin/bash -c 'mkdir -p __REPO_DIR__/its-a-plane-python/web/static/maps && chmod -R 777 __REPO_DIR__/its-a-plane-python/web/static/maps; touch __REPO_DIR__/its-a-plane-python/close.txt __REPO_DIR__/its-a-plane-python/farthest.txt && chmod 666 __REPO_DIR__/its-a-plane-python/close.txt __REPO_DIR__/its-a-plane-python/farthest.txt'

ExecStart=/usr/bin/python3 __REPO_DIR__/its-a-plane-python/its-a-plane.py
Restart=on-failure
RestartSec=10
# Run as root for GPIO / LED matrix access
User=root
Group=root

[Install]
WantedBy=multi-user.target
